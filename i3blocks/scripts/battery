#!/bin/sh

battery=""

for path in /sys/class/power_supply/BAT*; do
  if [ -d "$path" ]; then
    battery="$path"
    break
  fi
done

if [ -z "$battery" ]; then
  echo "B:--"
  echo "--"
  exit 0
fi

capacity=$(cat "$battery/capacity" 2>/dev/null)
status=$(cat "$battery/status" 2>/dev/null)

if [ -z "$capacity" ]; then
  echo "B:--"
  echo "--"
  exit 0
fi

suffix=""

case "$status" in
  Charging)
    suffix="+"
    ;;
  Full)
    suffix=""
    ;;
  Discharging)
    suffix=""
    ;;
esac

echo "B:${capacity}%${suffix}"
echo "${capacity}%${suffix}"

if [ "$capacity" -le 15 ] && [ "$status" = "Discharging" ]; then
  echo "#E67E80"   # Everforest Dark -- red
elif [ "$status" = "Charging" ]; then
  echo "#DBBC7F"   # Everforest Dark -- yellow
else
  echo "#7FBBB3"   # Everforest Dark -- blue
fi

exit 0